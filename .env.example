# =============================================================================
# Pi-Skills Platform — Environment Variable Reference
# Copy this file to .env.local for local development.
# Never commit .env or .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Application will refuse to start if these are missing
# -----------------------------------------------------------------------------

# JWT signing secret. Must be at least 32 characters, cryptographically random.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# PostgreSQL connection string (required in production; SQLite allowed in dev).
# Format: postgresql+asyncpg://user:password@host:5432/dbname
# Supabase example: postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
POSTGRES_DSN=

# Redis connection string (required in production; in-memory fallback in dev).
# Upstash example: rediss://default:[PASSWORD]@[ENDPOINT]:6380
REDIS_URL=

# -----------------------------------------------------------------------------
# RECOMMENDED — Warns on startup if missing in non-dev environments
# -----------------------------------------------------------------------------

# Sentry DSN for error tracking. Get from sentry.io project settings.
SENTRY_DSN=

# -----------------------------------------------------------------------------
# OPTIONAL — Defaults shown
# -----------------------------------------------------------------------------

# Application environment. Controls startup validation strictness.
# Values: development | staging | production
APP_ENV=development

APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
DEBUG=false

# JWT token expiry in hours (legacy; new TokenService uses 15-min access tokens)
JWT_EXPIRE_HOURS=24
JWT_ALGORITHM=HS256

# Redis cache TTLs (seconds)
REDIS_PERM_TTL=60
REDIS_MODEL_TTL=300
REDIS_RATE_WINDOW=60

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting
MAX_REQUESTS_PER_MINUTE=60
MAX_PROMPT_LENGTH=50000

# AI model API keys (only needed if using those providers)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Model adapter: litellm (default) or mock (tests only)
MODEL_ADAPTER_TYPE=litellm
ALLOW_MOCK_ADAPTER=false

# MCP bridge base URL (used by backend AgentExecutionService for internal calls)
MCP_BASE_URL=http://localhost:5001

# Snowflake (only needed if Snowflake integration is enabled)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# Bootstrap seed — creates initial admin/user/viewer accounts with random passwords.
# ONLY valid in development/test. Will raise if set to true in production.
ENABLE_BOOTSTRAP_SEED=false

# Auth routing (service boundary flags — do not change unless migrating)
GOVERNANCE_BACKEND_URL=http://localhost:8000
APPS_API_AUTH_PROXY_ENABLED=true
APPS_API_AUTH_ROUTES_ENABLED=true
GOVERNANCE_AUTH_TIMEOUT_SECONDS=5

# -----------------------------------------------------------------------------
# Frontend demo mode (Vite)
# -----------------------------------------------------------------------------
# When enabled, the frontend intercepts REST + MCP calls and returns dummy data.
# Note: only variables prefixed with VITE_ are exposed to the frontend.
VITE_DEMO_MODE=false
VITE_DEMO_LATENCY_MS=150
